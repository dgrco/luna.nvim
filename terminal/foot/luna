# Luna – default variant (soft-red accent)
# Foot terminal theme  (foot ≥ 1.8)
#
# Place in ~/.config/foot/themes/luna
# Then in foot.ini:
#   [colors]
#   alpha=1.0
#   include=~/.config/foot/themes/luna

[colors]
background=1B1D26
foreground=D7D7D7

selection-background=5E697E
selection-foreground=D7D7D7

# Foot uses foreground color for cursor by default — override in foot.ini:
#   [cursor]
#   color=1B1D26 D7D7D7

regular0=14161D
regular1=E07070
regular2=74C7A4
regular3=C4B05A
regular4=8DBBD3
regular5=C97070
regular6=AF98E6
regular7=D7D7D7

bright0=272932
bright1=D95555
bright2=76C5A4
bright3=E39A65
bright4=6CAEC0
bright5=E0828D
bright6=8DBBD3
bright7=E9E9E9

urls=C4B05A
